{
  "name": "@lattica/rest-api",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "infisical run -- bun run --hot src/index.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "db:generate": "infisical run -- drizzle-kit generate",
    "db:migrate": "infisical run -- drizzle-kit migrate",
    "db:push": "infisical run -- drizzle-kit push",
    "db:studio": "infisical run -- drizzle-kit studio",
    "db:test:up": "docker run --name test-pg -e POSTGRES_USER=test -e POSTGRES_PASSWORD=test -e POSTGRES_DB=test -p 5433:5432 -d postgres:18 && sleep 2 && DATABASE_URL=postgres://test:test@localhost:5433/test drizzle-kit migrate",
    "db:test:down": "docker rm -f test-pg",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.2",
    "@privy-io/node": "^0.10.0",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.1",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.1",
    "husky": "^9.1.7",
    "jose": "^6.1.3",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1"
  }
}
