{
  "name": "@lattica/rest-api",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vlt run -- bun run --hot src/index.ts",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "vlt run -- drizzle-kit migrate",
    "db:push": "vlt run -- drizzle-kit push",
    "db:studio": "vlt run -- drizzle-kit studio",
    "db:test:up": "docker run --name test-pg -e POSTGRES_USER=test -e POSTGRES_PASSWORD=test -e POSTGRES_DB=test -p 5433:5432 -d postgres:18 && sleep 2 && DATABASE_URL=postgres://test:test@localhost:5433/test drizzle-kit migrate",
    "db:test:down": "docker rm -f test-pg",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "prepare": "husky"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.3.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "jose": "^6.2.2",
    "postgres": "^3.4.9",
    "viem": "^2.47.16",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2"
  }
}
